rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Avatars: Publicly readable, writable only by the owner
    match /avatars/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && (
        fileName == request.auth.uid || 
        fileName.split('\\.')[0] == request.auth.uid
      );
    }
    
    // Novel Covers: Publicly readable, writable by any authenticated user (ideally author check)
    match /covers/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
